{
  "name": "rshono-monorepo",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "pnpm --filter rshono dev",
    "build": "pnpm --filter \"./examples/*\" build",
    "example:dev": "pnpm --filter rs-basic dev",
    "clean": "rm -rf packages/*/dist packages/*/node_modules examples/*/node_modules node_modules",
    "format": "prettier --write .",
    "uncomment": "prettier --plugin=prettier-plugin-uncomment --write ."
  },
  "devDependencies": {
    "prettier": "^3.9.1",
    "prettier-plugin-uncomment": "^1.0.2"
  }
}
