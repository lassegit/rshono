{
    "name": "rshono-monorepo",
    "private": true,
    "packageManager": "pnpm@11.9.0",
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "dev": "pnpm --filter rshono dev",
        "build": "pnpm --filter \"./packages/*\" build",
        "example:dev": "pnpm --filter rshono-example dev",
        "clean": "rm -rf packages/*/dist packages/*/node_modules examples/*/node_modules node_modules",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "prettier": "^3.9.1"
    }
}
