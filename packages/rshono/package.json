{
  "name": "rshono",
  "version": "0.1.0",
  "description": "Minimalist web framework — Hono + Rspack + React Server Components",
  "author": "Lasse <lasse@lassetange.com> (https://www.lassetange.com)",
  "license": "ISC",
  "keywords": [
    "react",
    "nextjs",
    "tanstack"
  ],
  "bugs": {
    "url": "https://github.com/lassegit/rshono/issues"
  },
  "homepage": "https://github.com/lassegit/rshono",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/runtime/context.ts",
      "import": "./src/runtime/context.ts"
    },
    "./client": {
      "types": "./src/runtime/client.ts",
      "import": "./src/runtime/client.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "rshono": "./bin/cli.cjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 \"test/*.test.mjs\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "@rspack/core": "^2.1.5",
    "@rspack/plugin-react-refresh": "^2.0.2",
    "react-refresh": "^0.18.0",
    "react-server-dom-rspack": "^0.0.2",
    "rsc-html-stream": "^0.0.7",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "hono": "^4.12.31",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "hono": "^4.8.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  }
}
