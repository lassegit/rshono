{
  "name": "rshono",
  "version": "0.1.0",
  "description": "Minimalist web framework — Hono + Rspack + React Server Components",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./server": {
      "types": "./src/runtime/context.ts",
      "import": "./src/runtime/context.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "rshono": "./bin/cli.cjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --test-concurrency=1 \"test/*.test.mjs\""
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@rspack/core": "^2.1.3",
    "@rspack/plugin-react-refresh": "^2.0.1",
    "react-refresh": "^0.18.0",
    "react-server-dom-rspack": "^0.0.2",
    "rsc-html-stream": "^0.0.7",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "hono": "^4.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "hono": "^4.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
