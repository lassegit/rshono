{
    "name": "rs-hono",
    "version": "0.1.0",
    "description": "Ultra-minimalist multipage framework — Hono + Rspack",
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./server": {
            "types": "./src/server/index.ts",
            "import": "./src/server/index.ts"
        },
        "./config": {
            "types": "./src/config.ts",
            "import": "./src/config.ts"
        },
        "./client": {
            "types": "./src/client.d.ts"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "rs-hono": "./bin/cli.cjs"
    },
    "files": [
        "src",
        "bin"
    ],
    "scripts": {
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@hono/node-server": "^2.0.8",
        "@rspack/core": "^2.1.3",
        "tsx": "^4.19.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "hono": "^4.8.0",
        "typescript": "^5.5.0"
    },
    "peerDependencies": {
        "hono": "^4.8.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    }
}
